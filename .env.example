# Copy to .env and adjust. Never commit .env.

PORT=4000

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vault_indexer

# EVM RPC endpoint the indexer reads from
RPC_URL=http://127.0.0.1:8545

# Address of the deployed StakingVault to index
VAULT_ADDRESS=0xYourDeployedStakingVault

# Block to start indexing from (the vault's deployment block)
START_BLOCK=0
